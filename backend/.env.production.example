# Production environment variables (set these in the Render dashboard).
# Do NOT commit real secrets.

ENVIRONMENT="production"
LOG_LEVEL="INFO"

# The deployed frontend origin(s), comma-separated. No trailing slash.
CORS_ORIGINS="https://your-app.vercel.app"

# Gemini (free tier). Use the rolling Flash-Lite alias.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-lite-latest"

# Optional
CACHE_TTL_SECONDS="300"
