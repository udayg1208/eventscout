# Copy this file to `.env` and fill in values. NEVER commit `.env`.

# --- Application ---
APP_NAME="Event Discovery Agent"
ENVIRONMENT="development"          # development | production
LOG_LEVEL="INFO"                  # DEBUG | INFO | WARNING | ERROR

# Comma-separated list of origins allowed to call this API (the frontend URL).
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# --- Gemini (query understanding) ---
# Get a free key at https://aistudio.google.com/app/apikey (no credit card).
# Leave blank to run on the deterministic keyword parser instead.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-lite-latest"

# --- Cache ---
# How long (seconds) a parsed query and its results stay cached.
CACHE_TTL_SECONDS="300"
