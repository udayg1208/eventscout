# Copy to `.env.local` for local dev. NEVER commit `.env.local`.
#
# Base URL of the backend API (no trailing slash).
#   Local dev:   http://127.0.0.1:8000
#   Production:  your Render backend URL, e.g. https://event-discovery-api.onrender.com
#
# NOTE: this is a NEXT_PUBLIC_* variable — it is inlined into the client bundle at
# BUILD time. On Vercel, set it in Project → Settings → Environment Variables and it is
# baked in on deploy. Changing it requires a rebuild.
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000"
